{
  "name": "wdl-field-forms",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "email-server": "node scripts/local-email-server.js",
    "firebase:deploy": "npm --prefix functions install && npx firebase-tools deploy --only functions",
    "firebase:serve": "npm --prefix functions install && npx firebase-tools emulators:start --only functions",
    "preview-web": "node scripts/static-preview-server.js",
    "web": "expo start --web",
    "web:build": "expo export --platform web --output-dir web-build",
    "web:preview": "node scripts/static-preview-server.js",
    "web:deploy": "npm run web:build && npx firebase-tools deploy --only hosting"
  },
  "dependencies": {
    "@emailjs/react-native": "^5.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sendgrid/mail": "^8.1.6",
    "expo": "~55.0.27",
    "expo-file-system": "~55.0.23",
    "expo-image-manipulator": "~55.0.18",
    "expo-image-picker": "~55.0.21",
    "expo-mail-composer": "~55.0.15",
    "expo-print": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "devDependencies": {
    "eas-cli": "^20.1.0"
  }
}
